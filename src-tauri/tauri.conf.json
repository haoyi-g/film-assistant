{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Film Assistant",
  "version": "0.1.0",
  "identifier": "com.filmassistant.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Film Assistant",
        "width": 1500,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/film-assistant/**", "$PICTURE/**", "$DOWNLOAD/**", "$DESKTOP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["bin/*"]
  }
}
